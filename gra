<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#211811">
  <title>Archiwum 221B — Zaginiona Kartoteka</title>
  <style>
    :root {
      --ink: #2a2119;
      --faded: #715f4b;
      --paper: #ead9b5;
      --paper-light: #f6ebce;
      --paper-dark: #b99a68;
      --red: #741f1b;
      --red-dark: #45100e;
      --gold: #a47a36;
      --shadow: rgba(20, 12, 7, .52);
    }

    * { box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--ink);
      font-family: Georgia, "Times New Roman", serif;
      background:
        radial-gradient(circle at 20% 10%, rgba(255,255,255,.07), transparent 26%),
        repeating-linear-gradient(105deg, rgba(255,255,255,.018) 0 1px, transparent 1px 5px),
        #211811;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      box-shadow: inset 0 0 110px #080503;
      z-index: 20;
    }

    button, input { font: inherit; }

    .app {
      width: min(920px, 100%);
      min-height: 100vh;
      margin: auto;
      padding: max(18px, env(safe-area-inset-top)) 14px max(34px, env(safe-area-inset-bottom));
    }

    .case-header {
      color: #eadbbd;
      text-align: center;
      padding: 14px 8px 22px;
      text-shadow: 0 2px 2px #000;
    }

    .eyebrow {
      margin: 0 0 8px;
      color: #bf9a5c;
      font-size: .73rem;
      letter-spacing: .32em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 8vw, 4.3rem);
      font-weight: 500;
      line-height: .98;
    }

    .subtitle {
      margin: 12px auto 0;
      color: #bda98a;
      font-style: italic;
      font-size: clamp(.95rem, 3vw, 1.2rem);
    }

    .progress-wrap {
      max-width: 640px;
      margin: 22px auto 0;
    }

    .progress-meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 7px;
      color: #bda98a;
      font-size: .75rem;
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    .progress-track {
      height: 6px;
      border: 1px solid #6b5336;
      background: #100c09;
      border-radius: 9px;
      overflow: hidden;
    }

    .progress-bar {
      width: 0;
      height: 100%;
      background: linear-gradient(90deg, var(--red), #b05f37, #d4aa58);
      transition: width .8s cubic-bezier(.2,.8,.2,1);
    }

    .file-tabs {
      display: flex;
      gap: 7px;
      justify-content: center;
      margin: 0 auto -2px;
      padding: 0 10px;
      position: relative;
      z-index: 2;
    }

    .tab {
      min-width: 45px;
      padding: 8px 11px 10px;
      border: 1px solid #927750;
      border-bottom: 0;
      border-radius: 7px 7px 0 0;
      color: #33271b;
      background: #aa9268;
      cursor: pointer;
      transition: transform .2s, background .2s, opacity .2s;
      box-shadow: 0 -3px 8px rgba(0,0,0,.16);
    }

    .tab:hover:not(:disabled) { transform: translateY(-3px); }
    .tab.active { background: var(--paper-light); transform: translateY(-4px); }
    .tab:disabled { opacity: .35; cursor: not-allowed; }
    .tab .lock { font-size: .72em; }

    .paper {
      position: relative;
      min-height: 520px;
      padding: clamp(25px, 6vw, 58px);
      background:
        linear-gradient(90deg, transparent 94%, rgba(71,46,23,.06)),
        radial-gradient(circle at 14% 17%, rgba(111,74,29,.12) 0 1px, transparent 2px),
        radial-gradient(circle at 82% 66%, rgba(111,74,29,.09) 0 2px, transparent 3px),
        repeating-linear-gradient(0deg, rgba(88,57,25,.025) 0 1px, transparent 1px 4px),
        var(--paper);
      border: 1px solid #a88959;
      box-shadow: 0 18px 55px var(--shadow), inset 0 0 55px rgba(107,72,30,.16);
      clip-path: polygon(.5% 1%, 7% .35%, 13% .8%, 21% .15%, 29% .75%, 38% .3%, 47% .8%, 56% .2%, 65% .7%, 74% .25%, 83% .75%, 92% .2%, 99.5% .8%, 99.2% 12%, 99.7% 24%, 99.1% 38%, 99.6% 51%, 99.2% 66%, 99.7% 79%, 99.1% 91%, 99.5% 99%, 89% 99.5%, 78% 99%, 67% 99.6%, 55% 99.1%, 44% 99.7%, 31% 99.2%, 17% 99.7%, .6% 99%, .9% 87%, .3% 73%, .8% 60%, .2% 45%, .7% 31%, .3% 16%);
    }

    .paper::after {
      content: "POUFNE";
      position: absolute;
      right: 5%;
      top: 4%;
      padding: 5px 10px;
      border: 3px double rgba(116,31,27,.45);
      color: rgba(116,31,27,.45);
      font: 700 clamp(.7rem, 3vw, 1rem) Arial, sans-serif;
      letter-spacing: .18em;
      transform: rotate(7deg);
    }

    .chapter { display: none; }
    .chapter.active { display: block; animation: pageIn .7s cubic-bezier(.18,.8,.25,1) both; }
    .chapter.leaving { display: block; animation: pageOut .33s ease both; }

    @keyframes pageIn {
      from { opacity: 0; transform: translateX(34px) rotate(.7deg); filter: blur(3px); }
      to { opacity: 1; transform: none; filter: blur(0); }
    }

    @keyframes pageOut {
      to { opacity: 0; transform: translateX(-28px) rotate(-.5deg); filter: blur(2px); }
    }

    .chapter-number {
      display: inline-block;
      margin: 0 0 16px;
      color: var(--red);
      font: 700 .75rem Arial, sans-serif;
      letter-spacing: .2em;
      text-transform: uppercase;
    }

    h2 {
      max-width: 700px;
      margin: 0 0 9px;
      font-size: clamp(1.8rem, 6vw, 3.1rem);
      line-height: 1.04;
      font-weight: 500;
    }

    .location {
      margin: 0 0 25px;
      color: var(--faded);
      font-size: .9rem;
      font-style: italic;
    }

    .story {
      font-size: clamp(1rem, 2.8vw, 1.15rem);
      line-height: 1.65;
    }

    .story::first-letter {
      float: left;
      margin: 3px 7px 0 0;
      color: var(--red);
      font-size: 3.3rem;
      line-height: .75;
    }

    .clue {
      position: relative;
      margin: 26px 0;
      padding: 22px clamp(18px, 5vw, 34px);
      border: 1px solid rgba(88,58,28,.42);
      background: rgba(255,250,226,.44);
      box-shadow: inset 0 0 22px rgba(80,50,20,.08), 3px 5px 0 rgba(79,52,27,.08);
      transform: rotate(-.25deg);
    }

    .clue::before {
      content: "DOWÓD RZECZOWY";
      position: absolute;
      top: -10px;
      left: 16px;
      padding: 3px 8px;
      color: #f1dfbd;
      background: var(--red);
      font: 700 .62rem Arial, sans-serif;
      letter-spacing: .13em;
    }

    .cipher {
      text-align: center;
      font-size: clamp(1.05rem, 4.2vw, 1.55rem);
      line-height: 1.8;
      letter-spacing: .12em;
      font-weight: 700;
      word-break: break-word;
    }

    .note { font-style: italic; line-height: 1.6; }
    .acrostic span { display: block; }
    .acrostic span::first-letter { color: var(--red); font-weight: 700; font-size: 1.25em; }

    .answer-box {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      margin-top: 28px;
    }

    .answer-box label {
      grid-column: 1 / -1;
      color: var(--faded);
      font: 700 .7rem Arial, sans-serif;
      letter-spacing: .15em;
      text-transform: uppercase;
    }

    .answer {
      min-width: 0;
      padding: 13px 14px;
      border: 0;
      border-bottom: 2px solid #6e5739;
      border-radius: 0;
      outline: none;
      color: var(--ink);
      background: rgba(255,255,255,.25);
      box-shadow: inset 0 -4px 0 rgba(95,67,34,.05);
    }

    .answer:focus { border-color: var(--red); background: rgba(255,255,255,.4); }

    .submit {
      padding: 12px 18px;
      border: 0;
      border-radius: 2px;
      color: #f3dfbd;
      background: linear-gradient(#832a24, #5a1714);
      box-shadow: 0 4px 0 #35100e, 0 7px 12px rgba(0,0,0,.2);
      cursor: pointer;
      font: 700 .75rem Arial, sans-serif;
      letter-spacing: .1em;
      text-transform: uppercase;
      transition: transform .15s, filter .15s;
    }

    .submit:hover { filter: brightness(1.12); }
    .submit:active { transform: translateY(3px); box-shadow: 0 1px 0 #35100e; }

    .feedback {
      grid-column: 1 / -1;
      min-height: 24px;
      margin: 2px 0 0;
      font-size: .92rem;
      font-style: italic;
    }

    .feedback.error { color: #7c1d18; animation: shake .35s ease; }
    .feedback.success { color: #31532a; font-weight: 700; }

    @keyframes shake {
      25% { transform: translateX(-5px); }
      50% { transform: translateX(5px); }
      75% { transform: translateX(-3px); }
    }

    .seal {
      position: absolute;
      right: clamp(18px, 5vw, 48px);
      bottom: 28px;
      width: 76px;
      height: 76px;
      display: grid;
      place-items: center;
      border: 4px double #a64136;
      border-radius: 50%;
      color: #a64136;
      opacity: .48;
      transform: rotate(-13deg);
      font: 700 .58rem Arial, sans-serif;
      letter-spacing: .08em;
      text-align: center;
    }

    .complete-card { text-align: center; padding: 35px 0 90px; }
    .complete-card .big-seal {
      width: 120px;
      height: 120px;
      display: grid;
      place-items: center;
      margin: 24px auto;
      border: 8px double var(--red);
      border-radius: 50%;
      color: var(--red);
      transform: rotate(-8deg);
      font: 700 .8rem Arial, sans-serif;
      letter-spacing: .08em;
      animation: stamp .55s cubic-bezier(.2,1.7,.4,1) both;
    }

    @keyframes stamp {
      from { opacity: 0; transform: scale(2.5) rotate(-8deg); }
      to { opacity: 1; transform: scale(1) rotate(-8deg); }
    }

    .reset {
      margin-top: 16px;
      border: 0;
      border-bottom: 1px solid currentColor;
      color: var(--faded);
      background: transparent;
      cursor: pointer;
      font-size: .82rem;
    }

    .case-footer { padding: 18px; color: #7f705e; text-align: center; font-size: .75rem; }

    @media (max-width: 560px) {
      .app { padding-left: 8px; padding-right: 8px; }
      .paper { min-height: 610px; }
      .answer-box { grid-template-columns: 1fr; }
      .answer-box label, .feedback { grid-column: auto; }
      .submit { width: 100%; min-height: 47px; }
      .tab { min-width: 40px; padding: 8px 7px 10px; }
      .paper::after { top: 2.5%; }
      .seal { bottom: 20px; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: .01ms !important; transition-duration: .01ms !important; }
    }
  </style>
</head>
<body>
  <main class="app">
    <header class="case-header">
      <p class="eyebrow">Prywatne archiwum Sherlocka Holmesa</p>
      <h1>Zaginiona Kartoteka</h1>
      <p class="subtitle">Sprawa nr 1888/221B · Londyn tonie we mgle</p>
      <div class="progress-wrap" aria-label="Postęp śledztwa">
        <div class="progress-meta"><span>Postęp śledztwa</span><span id="progressText">0 / 5</span></div>
        <div class="progress-track"><div class="progress-bar" id="progressBar"></div></div>
      </div>
    </header>

    <nav class="file-tabs" id="tabs" aria-label="Rozdziały sprawy"></nav>

    <section class="paper" id="caseFile">

      <!-- ============================================================
           ZAGADKA 1: Telegram ze Scotland Yardu
           Hasło: KRUK
           ============================================================ -->
      <article class="chapter active" data-chapter="0" data-answer="kruk">
        <span class="chapter-number">Rozdział I · Telegram</span>
        <h2>Posłaniec we mgle</h2>
        <p class="location">Baker Street 221B, wtorek, godzina 6:40</p>
        <p class="story">Inspektor Lestrade zjawia się przed świtem. Z tajnego archiwum Scotland Yardu zniknęła kartoteka agentów. Na biurku pozostał tylko telegram, którego każde zdanie brzmi podejrzanie zwyczajnie.</p>
        <div class="clue acrostic">
          <span><b>K</b>areta czekała przed północą.</span>
          <span><b>R</b>zeka skryła ślady przewoźnika.</span>
          <span><b>U</b>liczny gaz zgasł dokładnie o dwunastej.</span>
          <span><b>K</b>lucz pozostał po wewnętrznej stronie drzwi.</span>
        </div>
        <p class="note">Holmes: „Gdy wiadomość donikąd nie prowadzi, Watsonie, zacznij od początku każdej myśli.”</p>
        <div class="answer-box">
          <label for="answer-0">Wpisz znak rozpoznawczy złodzieja</label>
          <input class="answer" id="answer-0" autocomplete="off" placeholder="Twoje hasło…">
          <button class="submit" type="button">Sprawdź trop</button>
          <p class="feedback" aria-live="polite"></p>
        </div>
        <div class="seal">SCOTLAND<br>YARD</div>
      </article>

      <!-- ============================================================
           ZAGADKA 2: Szyfr Cezara
           Hasło: SKRZYPCE
           ============================================================ -->
      <article class="chapter" data-chapter="1" data-answer="skrzypce">
        <span class="chapter-number">Rozdział II · Mieszkanie podejrzanego</span>
        <h2>Pokój bez muzyki</h2>
        <p class="location">Whitechapel, Hanbury Street 14, godzina 9:15</p>
        <p class="story">W pustym pokoju „Kruka” znajduje się pasek papieru i rzymska moneta z cyfrą III. Holmes przesuwa każdą literę wiadomości o trzy miejsca wstecz w alfabecie.</p>
        <div class="clue">
          <div class="cipher">V N U C B S F H</div>
        </div>
        <p class="note">Wskazówka: alfabet bez polskich znaków. Cofnij każdą literę o 3: D → A, E → B…</p>
        <div class="answer-box">
          <label for="answer-1">Jaki przedmiot wskazuje szyfr?</label>
          <input class="answer" id="answer-1" autocomplete="off" placeholder="Twoje hasło…">
          <button class="submit" type="button">Sprawdź trop</button>
          <p class="feedback" aria-live="polite"></p>
        </div>
        <div class="seal">DOWÓD<br>NR 17</div>
      </article>

      <!-- ============================================================
           ZAGADKA 3: Nuty i liczby
           Hasło: 221B
           ============================================================ -->
      <article class="chapter" data-chapter="2" data-answer="221b">
        <span class="chapter-number">Rozdział III · Futerał</span>
        <h2>Melodia adresów</h2>
        <p class="location">Hanbury Street 14, kilka minut później</p>
        <p class="story">W futerale skrzypiec ukryto cztery symbole zapisane innym atramentem. Holmes zauważa, że pierwsze trzy są cyframi rzymskimi, a ostatni wskazuje literę.</p>
        <div class="clue">
          <div class="cipher">II &nbsp;·&nbsp; II &nbsp;·&nbsp; I &nbsp;·&nbsp; Baker<sup>1</sup></div>
        </div>
        <p class="note">Wskazówka: zamień cyfry rzymskie na arabskie, a z nazwy ulicy wybierz pierwszą literę. Wynik jest londyńskim adresem.</p>
        <div class="answer-box">
          <label for="answer-2">Dokąd prowadzi trop?</label>
          <input class="answer" id="answer-2" autocomplete="off" placeholder="Np. 123A…">
          <button class="submit" type="button">Sprawdź trop</button>
          <p class="feedback" aria-live="polite"></p>
        </div>
        <div class="seal">TAJNE<br>AKTA</div>
      </article>

      <!-- ============================================================
           ZAGADKA 4: Kod książkowy
           Hasło: MORIARTY
           ============================================================ -->
      <article class="chapter" data-chapter="3" data-answer="moriarty">
        <span class="chapter-number">Rozdział IV · Ukryta skrytka</span>
        <h2>Osiem nazwisk</h2>
        <p class="location">Baker Street 221B, godzina 13:05</p>
        <p class="story">Za luźną deską Holmes odnajduje wykaz ośmiu świadków. Obok każdego nazwiska widnieje liczba. „Proste zamki bywają najlepsze” — mówi, wybierając z każdego nazwiska wskazaną literę.</p>
        <div class="clue">
          <div class="cipher" style="font-size:clamp(.9rem,3.6vw,1.25rem);text-align:left">
            1. <u>M</u>urray [1]<br>
            2. Hobbs [2]<br>
            3. Parker [3]<br>
            4. Finch [2]<br>
            5. Adler [1]<br>
            6. Carter [3]<br>
            7. Tate [1]<br>
            8. Gray [4]
          </div>
        </div>
        <p class="note">Wskazówka: [3] oznacza trzecią literę nazwiska. Zapisz wszystkie po kolei.</p>
        <div class="answer-box">
          <label for="answer-3">Kto kieruje kradzieżą?</label>
          <input class="answer" id="answer-3" autocomplete="off" placeholder="Nazwisko…">
          <button class="submit" type="button">Sprawdź trop</button>
          <p class="feedback" aria-live="polite"></p>
        </div>
        <div class="seal">ŚCIŚLE<br>TAJNE</div>
      </article>

      <!-- ============================================================
           ZAGADKA 5: Lustro Irene Adler
           Hasło: IRENE
           ============================================================ -->
      <article class="chapter" data-chapter="4" data-answer="irene">
        <span class="chapter-number">Rozdział V · Ostatnia wiadomość</span>
        <h2>Kobieta za lustrem</h2>
        <p class="location">Opuszczony teatr, Covent Garden, godzina 23:50</p>
        <p class="story">Moriarty zastawił pułapkę, lecz kartoteki już nie ma. Na zakurzonym lustrze ktoś napisał pięć grup kresek. Holmes odczytuje je jako numery liter alfabetu.</p>
        <div class="clue">
          <div class="cipher">9 &nbsp;·&nbsp; 18 &nbsp;·&nbsp; 5 &nbsp;·&nbsp; 14 &nbsp;·&nbsp; 5</div>
        </div>
        <p class="note">Wskazówka: A = 1, B = 2, C = 3… Kto przechytrzył profesora i ocalił akta?</p>
        <div class="answer-box">
          <label for="answer-4">Podaj imię tajemniczej wybawicielki</label>
          <input class="answer" id="answer-4" autocomplete="off" placeholder="Imię…">
          <button class="submit" type="button">Zamknij sprawę</button>
          <p class="feedback" aria-live="polite"></p>
        </div>
        <div class="seal">OSTATNI<br>TROP</div>
      </article>

      <!-- EKRAN ZAKOŃCZENIA -->
      <article class="chapter" data-chapter="5">
        <div class="complete-card">
          <span class="chapter-number">Raport końcowy</span>
          <h2>Sprawa rozwiązana</h2>
          <div class="big-seal">ZAMKNIĘTE<br>221B</div>
          <p class="story" style="max-width:590px;margin:0 auto">Kartoteka wróciła do Scotland Yardu, Moriarty został zmuszony do odwrotu, a pani Irene Adler — jak zwykle — zniknęła przed przybyciem policji.</p>
          <p class="note">„Eliminuj niemożliwe, a to, co pozostanie, musi być prawdą.”</p>
          <button class="reset" id="resetGame" type="button">Wyczyść akta i rozpocznij od nowa</button>
        </div>
      </article>
    </section>

    <footer class="case-footer">Archiwum 221B · Postęp jest zapisywany wyłącznie na tym urządzeniu</footer>
  </main>

  <script>
    /* ================================================================
       USTAWIENIA GRY
       Aby zmienić hasło, edytuj atrybut data-answer przy danej zagadce.
       Odpowiedzi nie rozróżniają wielkości liter, spacji ani polskich znaków.
       ================================================================ */
    const chapters = [...document.querySelectorAll('.chapter')];
    const puzzleCount = 5;
    const storageKey = 'archiwum221b-progress';
    const tabs = document.getElementById('tabs');
    const progressBar = document.getElementById('progressBar');
    const progressText = document.getElementById('progressText');

    let unlocked = Math.min(Number(localStorage.getItem(storageKey)) || 0, puzzleCount);
    let current = unlocked === puzzleCount ? puzzleCount : unlocked;

    function normalize(text) {
      return text
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]/g, '');
    }

    function buildTabs() {
      tabs.innerHTML = '';
      for (let i = 0; i < puzzleCount; i++) {
        const button = document.createElement('button');
        button.className = 'tab';
        button.type = 'button';
        button.disabled = i > unlocked;
        button.setAttribute('aria-label', i > unlocked ? `Rozdział ${i + 1}, zablokowany` : `Otwórz rozdział ${i + 1}`);
        button.innerHTML = i > unlocked ? `<span class="lock">◆</span>` : `${i + 1}`;
        button.addEventListener('click', () => showChapter(i));
        tabs.appendChild(button);
      }
      updateTabs();
    }

    function updateTabs() {
      [...tabs.children].forEach((tab, i) => {
        tab.disabled = i > unlocked;
        tab.classList.toggle('active', i === current && current < puzzleCount);
        tab.innerHTML = i > unlocked ? '<span class="lock">◆</span>' : (i < unlocked ? '✓' : `${i + 1}`);
      });
      progressBar.style.width = `${(unlocked / puzzleCount) * 100}%`;
      progressText.textContent = `${unlocked} / ${puzzleCount}`;
    }

    function showChapter(index) {
      if (index > unlocked || index === current) return;
      const old = chapters[current];
      old.classList.add('leaving');
      old.classList.remove('active');

      window.setTimeout(() => {
        old.classList.remove('leaving');
        current = index;
        chapters.forEach((chapter, i) => chapter.classList.toggle('active', i === current));
        updateTabs();
        document.getElementById('caseFile').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 300);
    }

    function checkAnswer(chapter) {
      const input = chapter.querySelector('.answer');
      const feedback = chapter.querySelector('.feedback');
      const expected = normalize(chapter.dataset.answer);
      const given = normalize(input.value);
      const index = Number(chapter.dataset.chapter);

      feedback.className = 'feedback';

      if (!given) {
        feedback.textContent = 'Najpierw wpisz odpowiedź, detektywie.';
        feedback.classList.add('error');
        input.focus();
        return;
      }

      if (given !== expected) {
        feedback.textContent = 'Ten trop prowadzi donikąd. Przyjrzyj się dowodowi jeszcze raz.';
        feedback.classList.add('error');
        input.select();
        return;
      }

      feedback.textContent = 'Trafna dedukcja. Kolejny rozdział został odblokowany.';
      feedback.classList.add('success');
      input.disabled = true;

      if (index >= unlocked) {
        unlocked = Math.min(index + 1, puzzleCount);
        localStorage.setItem(storageKey, unlocked);
      }
      buildTabs();
      window.setTimeout(() => showChapter(index + 1), 900);
    }

    document.querySelectorAll('.submit').forEach(button => {
      const chapter = button.closest('.chapter');
      button.addEventListener('click', () => checkAnswer(chapter));
      chapter.querySelector('.answer').addEventListener('keydown', event => {
        if (event.key === 'Enter') checkAnswer(chapter);
      });
    });

    document.getElementById('resetGame').addEventListener('click', () => {
      localStorage.removeItem(storageKey);
      unlocked = 0;
      document.querySelectorAll('.answer').forEach(input => {
        input.value = '';
        input.disabled = false;
      });
      document.querySelectorAll('.feedback').forEach(item => item.textContent = '');
      current = 5;
      buildTabs();
      showChapter(0);
    });

    buildTabs();
    chapters.forEach((chapter, i) => chapter.classList.toggle('active', i === current));
    updateTabs();
  </script>
</body>
</html>
